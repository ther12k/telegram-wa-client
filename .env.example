# Telewa environment variables
# Copy to .env (gitignored) and fill in real values for production deploys.

# --- Runtime mode ---
APP_ENV=development               # "development" (demo + dev tools) | "production" (real Telegram if creds present)
PORT=3001                         # Container-internal port; docker-compose maps to 3101 on host
PUBLIC_BASE_URL=http://localhost:5173
DEMO_MODE=true                    # true = FakeTelegramAdapter (any code 11111 logs you in as `me`); false = real adapter if creds present
DATABASE_PATH=./data/app.db       # SQLite path for future persistent state (not used yet)
MAX_UPLOAD_BYTES=104857600        # 100 MB upload cap
LOG_LEVEL=info

# --- Real Telegram (MTProto) ---
# Get these from https://my.telegram.org → "API development tools" → "Create new application".
# Without these, the app falls back to the FakeTelegramAdapter even when APP_ENV=production.
TELEGRAM_API_ID=                  # numeric, e.g. 12345678
TELEGRAM_API_HASH=                # 32-char hex, e.g. a1b2c3d4e5f67890abcdef1234567890
#
# Note (2026-06-22): at-rest encryption of the MTProto session SQLite DB was
# scoped for Story 2+ — mtcute 0.8.0's SqliteStorage does not yet accept an
# encryption key. When it does, the SESSION_ENCRYPTION_KEY knob will return here.

# --- Session secret ---
APP_SESSION_SECRET=change-me-in-production
